 141:./inc/main.h  **** __STATIC_FORCEINLINE void init_systick(void) {
 142:./inc/main.h  **** 
 143:./inc/main.h  ****   /* Initialize SysTick to 1 ms period */
 144:./inc/main.h  **** 
 145:./inc/main.h  ****   SysTick->LOAD = HCLK * 1000 / (8 - SYSTICK_CLOCK_SOURCE * 7) - 1;
 146:./inc/main.h  ****   SysTick->VAL  = SysTick->LOAD;
 147:./inc/main.h  ****   SysTick->CTRL = (
 148:./inc/main.h  ****     + SYSTICK_CLOCK_SOURCE * SysTick_CTRL_CLKSOURCE_Msk
 149:./inc/main.h  ****     + SYSTICK_IRQ_EN       * SysTick_CTRL_TICKINT_Msk
 150:./inc/main.h  ****     + SYSTICK_EN           * SysTick_CTRL_ENABLE_Msk
 151:./inc/main.h  ****   );
 152:./inc/main.h  **** } /* init_systick() */
