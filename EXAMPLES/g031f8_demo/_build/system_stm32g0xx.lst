 195:./src/system_stm32g0xx.c **** /**
 196:./src/system_stm32g0xx.c ****   * @brief  Update SystemCoreClock variable according to Clock Register Values.
 197:./src/system_stm32g0xx.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 198:./src/system_stm32g0xx.c ****   *         be used by the user application to setup the SysTick timer or configure
 199:./src/system_stm32g0xx.c ****   *         other parameters.
 200:./src/system_stm32g0xx.c ****   *
 201:./src/system_stm32g0xx.c ****   * @note   Each time the core clock (HCLK) changes, this function must be called
 202:./src/system_stm32g0xx.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 203:./src/system_stm32g0xx.c ****   *         based on this variable will be incorrect.
 204:./src/system_stm32g0xx.c ****   *
 205:./src/system_stm32g0xx.c ****   * @note   - The system frequency computed by this function is not the real
 206:./src/system_stm32g0xx.c ****   *           frequency in the chip. It is calculated based on the predefined
 207:./src/system_stm32g0xx.c ****   *           constant and the selected clock source:
 208:./src/system_stm32g0xx.c ****   *
 209:./src/system_stm32g0xx.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(**) / HSI divis
 210:./src/system_stm32g0xx.c ****   *
 211:./src/system_stm32g0xx.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(***)
 212:./src/system_stm32g0xx.c ****   *
 213:./src/system_stm32g0xx.c ****   *           - If SYSCLK source is LSI, SystemCoreClock will contain the LSI_VALUE
 214:./src/system_stm32g0xx.c ****   *
 215:./src/system_stm32g0xx.c ****   *           - If SYSCLK source is LSE, SystemCoreClock will contain the LSE_VALUE
 216:./src/system_stm32g0xx.c ****   *
 217:./src/system_stm32g0xx.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the HSE_VALUE(***)
 218:./src/system_stm32g0xx.c ****   *             or HSI_VALUE(*) multiplied/divided by the PLL factors.
 219:./src/system_stm32g0xx.c ****   *
 220:./src/system_stm32g0xx.c ****   *         (**) HSI_VALUE is a constant defined in stm32g0xx_hal_conf.h file (default value
 221:./src/system_stm32g0xx.c ****   *              16 MHz) but the real value may vary depending on the variations
 222:./src/system_stm32g0xx.c ****   *              in voltage and temperature.
 223:./src/system_stm32g0xx.c ****   *
 224:./src/system_stm32g0xx.c ****   *         (***) HSE_VALUE is a constant defined in stm32g0xx_hal_conf.h file (default value
 225:./src/system_stm32g0xx.c ****   *              8 MHz), user has to ensure that HSE_VALUE is same as the real
 226:./src/system_stm32g0xx.c ****   *              frequency of the crystal used. Otherwise, this function may
 227:./src/system_stm32g0xx.c ****   *              have wrong result.
 228:./src/system_stm32g0xx.c ****   *
 229:./src/system_stm32g0xx.c ****   *         - The result of this function could be not correct when using fractional
 230:./src/system_stm32g0xx.c ****   *           value for HSE crystal.
 231:./src/system_stm32g0xx.c ****   *
 232:./src/system_stm32g0xx.c ****   * @param  None
 233:./src/system_stm32g0xx.c ****   * @retval None
 234:./src/system_stm32g0xx.c ****   */
 235:./src/system_stm32g0xx.c **** void SystemCoreClockUpdate(void)
