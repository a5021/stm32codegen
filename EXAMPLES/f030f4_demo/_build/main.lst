   6:./src/main.c  **** /**
   7:./src/main.c  ****   * @brief TIM1 Control Register 1 (TIM1_CR1) structure definition
   8:./src/main.c  ****   * @details This union provides type-safe access to the TIM1 control register bits.
   9:./src/main.c  ****   *          It exactly mirrors the hardware register layout described in the STM32
  10:./src/main.c  ****   *          reference manual (RM0360 section 13.4.1 for STM32F030xx timers).
  11:./src/main.c  ****   *          
  12:./src/main.c  ****   *          Using uint32_t ensures proper memory alignment despite the register
  13:./src/main.c  ****   *          being 16-bit, which is critical for atomic operations on Cortex-M0.
  14:./src/main.c  ****   * 
  15:./src/main.c  ****   * @note Register characteristics:
  16:./src/main.c  ****   *       - Physical size: 16 bits (using 32-bit storage for compatibility)
  17:./src/main.c  ****   *       - Bit order: Little-endian (LSB at bit position 0)
ARM GAS  C:\Users\MR20AF~1.SMI\AppData\Local\Temp\ccbEfuia.s 			page 7


  18:./src/main.c  ****   *       - Reset state: 0x0000 (all bits cleared)
  19:./src/main.c  ****   *       - Access: Read/write (except reserved bits)
  20:./src/main.c  ****   */
  21:./src/main.c  **** typedef union {
  22:./src/main.c  ****   uint32_t r; // Combined register access for atomic operations
  23:./src/main.c  ****   struct {
  24:./src/main.c  ****     /* Bitfield layout matches hardware exactly - do not reorder */
  25:./src/main.c  ****     uint32_t CEN  : 1;  // [0]     Counter enable control
  26:./src/main.c  ****                         //         0: Timer disabled
  27:./src/main.c  ****                         //         1: Timer enabled
  28:./src/main.c  ****     uint32_t UDIS : 1;  // [1]     Update event disable
  29:./src/main.c  ****                         //         0: Update events enabled
  30:./src/main.c  ****                         //         1: Update events disabled
  31:./src/main.c  ****     uint32_t URS  : 1;  // [2]     Update request source selector
  32:./src/main.c  ****                         //         0: Any of: Counter overflow/underflow, setting UG bit, trigger e
  33:./src/main.c  ****                         //         1: Only counter overflow/underflow
  34:./src/main.c  ****     uint32_t OPM  : 1;  // [3]     One-pulse mode control
  35:./src/main.c  ****                         //         0: Continuous mode
  36:./src/main.c  ****                         //         1: One-pulse mode (stops after next update)
  37:./src/main.c  ****     uint32_t DIR  : 1;  // [4]     Counting direction
  38:./src/main.c  ****                         //         0: Upcounter (incrementing)
  39:./src/main.c  ****                         //         1: Downcounter (decrementing)
  40:./src/main.c  ****     uint32_t CMS  : 2;  // [6:5]   Counter alignment mode
  41:./src/main.c  ****                         //         00: Edge-aligned mode
  42:./src/main.c  ****                         //         01: Center-aligned mode 1
  43:./src/main.c  ****                         //         10: Center-aligned mode 2
  44:./src/main.c  ****                         //         11: Center-aligned mode 3
  45:./src/main.c  ****     uint32_t ARPE : 1;  // [7]     Auto-reload preload enable
  46:./src/main.c  ****                         //         0: ARR register not buffered
  47:./src/main.c  ****                         //         1: ARR register buffered
  48:./src/main.c  ****     uint32_t CKD  : 2;  // [9:8]   Clock division factor
  49:./src/main.c  ****                         //         00: tDTS = tCK_INT (no division)
  50:./src/main.c  ****                         //         01: tDTS = 2 × tCK_INT
  51:./src/main.c  ****                         //         10: tDTS = 4 × tCK_INT
  52:./src/main.c  ****                         //         11: Reserved
  53:./src/main.c  ****     uint32_t      : 22; // [31:10] Reserved bits - must maintain reset value
  54:./src/main.c  ****   };
  55:./src/main.c  **** } TIM1_CR1_t;
