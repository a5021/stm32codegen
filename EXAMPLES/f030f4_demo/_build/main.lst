 169:./src/main.c  ****   /* METHOD 2: Explicit bit-weighted initialization
 170:./src/main.c  ****    * Advantages:
 171:./src/main.c  ****    * - Self-documenting through comments
 172:./src/main.c  ****    * - Explicit about each bit's value
 173:./src/main.c  ****    * 
 174:./src/main.c  ****    * Disadvantages:
 175:./src/main.c  ****    * - Verbose syntax
 176:./src/main.c  ****    */
 177:./src/main.c  ****   TIM1->CR1 = (
 178:./src/main.c  ****     1 * TIM_CR1_CEN      |   /* Enable counter */
 179:./src/main.c  ****     0 * TIM_CR1_UDIS     |   /* Allow update events */
 180:./src/main.c  ****     1 * TIM_CR1_URS      |   /* Only overflow triggers update */
 181:./src/main.c  ****     0 * TIM_CR1_OPM      |   /* Continuous counting mode */
 182:./src/main.c  ****     0 * TIM_CR1_DIR      |   /* Up-counting direction */
 183:./src/main.c  ****     1 * TIM_CR1_CMS_0    |   /* Center-aligned mode 1 */
 184:./src/main.c  ****     0 * TIM_CR1_CMS_1    |
 185:./src/main.c  ****     1 * TIM_CR1_ARPE     |   /* Enable auto-reload buffering */
 186:./src/main.c  ****     1 * TIM_CR1_CKD_0    |   /* Clock division = 2 */
 187:./src/main.c  ****     0 * TIM_CR1_CKD_1
 188:./src/main.c  ****   );
 189:./src/main.c  ****   
 190:./src/main.c  **** 
 191:./src/main.c  ****   /* METHOD 3: Compile-time configuration macro
 192:./src/main.c  ****    * Advantages:
 193:./src/main.c  ****    * - Configuration separated from code
 194:./src/main.c  ****    * - Conditional compilation possible
 195:./src/main.c  ****    * 
 196:./src/main.c  ****    * Disadvantages:
 197:./src/main.c  ****    * - Complex preprocessor usage
 198:./src/main.c  ****    * - Harder to debug
 199:./src/main.c  ****    */
 200:./src/main.c  ****   #define TIM1_CR1_INIT  (                                                      \
 201:./src/main.c  ****     0 * TIM_CR1_CEN      |   /* Counter enable                                */\
 202:./src/main.c  ****     0 * TIM_CR1_UDIS     |   /* Update disable                                */\
 203:./src/main.c  ****     0 * TIM_CR1_URS      |   /* Update request source                         */\
 204:./src/main.c  ****     0 * TIM_CR1_OPM      |   /* One pulse mode                                */\
 205:./src/main.c  ****     0 * TIM_CR1_DIR      |   /* Direction                                     */\
 206:./src/main.c  ****                                                                                 \
 207:./src/main.c  ****     0 * TIM_CR1_CMS      |   /* CMS[1:0] bits (Center-aligned mode selection) */\
 208:./src/main.c  ****     0 * TIM_CR1_CMS_0    |   /*  0x00000020                                   */\
 209:./src/main.c  ****     0 * TIM_CR1_CMS_1    |   /*  0x00000040                                   */\
 210:./src/main.c  ****                                                                                 \
 211:./src/main.c  ****     0 * TIM_CR1_ARPE     |   /* Auto-reload preload enable                    */\
 212:./src/main.c  ****                                                                                 \
 213:./src/main.c  ****     0 * TIM_CR1_CKD      |   /* CKD[1:0] bits (clock division)                */\
 214:./src/main.c  ****     0 * TIM_CR1_CKD_0    |   /*  0x00000100                                   */\
